# Database
DATABASE_URL=postgresql://formiq:password@localhost:5432/formiq

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-this-to-a-long-random-string-in-production

# AI - Azure Document Intelligence (Primary)
AZURE_DI_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_DI_KEY=your-azure-key
AZURE_DI_MODEL_ID=prebuilt-document
AZURE_DI_CONFIDENCE_THRESHOLD=0.70

# AI - OpenAI (Fallback cleanup/entities)
OPENAI_API_KEY=sk-proj-...

# AI - Anthropic (Optional fallback)
ANTHROPIC_API_KEY=sk-ant-...

# File Storage (Cloudflare R2 or AWS S3)
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=formiq-documents

# Stripe (optional for billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info
