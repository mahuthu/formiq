# ─── Required ──────────────────────────────────────────────────────────────────

# AI - Azure Form Recognizer (Primary)
AZURE_FORM_RECOGNIZER_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_FORM_RECOGNIZER_KEY=your-azure-key
AZURE_DI_MODEL_ID=prebuilt-document
AZURE_DI_CONFIDENCE_THRESHOLD=0.70

# AI - Azure OpenAI (Fallback cleanup/entities)
AZURE_OPENAI_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1-mini

# AI - Anthropic (Legacy/Optional)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Auth - generate with: openssl rand -hex 32
JWT_SECRET=your-secret-key-here

# Database - update YOUR_SECURE_PASSWORD for production
DATABASE_URL=postgresql://formiq:YOUR_SECURE_PASSWORD@localhost:5436/formiq
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD

# Storage - Cloudflare R2 (recommended) or AWS S3
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET=formiq-documents

# ─── Optional ──────────────────────────────────────────────────────────────────

# Public URLs (update for production deployment)
# e.g., http://20.250.163.236:8080
FRONTEND_URL=http://20.250.163.236:8080
# e.g., http://20.250.163.236:8080/api
NEXT_PUBLIC_API_URL=http://20.250.163.236:8080/api

# ─── Paystack billing (optional) ───────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_WEBHOOK_SECRET=your-webhook-secret-hash

# Plan Codes
PAYSTACK_STARTER_PLAN_CODE=PLN_...
PAYSTACK_PROFESSIONAL_PLAN_CODE=PLN_...
