# ─── Required ──────────────────────────────────────────────────────────────────

# AI - Get from https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key

# Auth - generate with: openssl rand -hex 32
JWT_SECRET=your-secret-key-here

# Database - update YOUR_SECURE_PASSWORD for production
DATABASE_URL=postgresql://formiq:YOUR_SECURE_PASSWORD@postgres:5432/formiq
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD

# Storage - Cloudflare R2 (recommended) or AWS S3
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET=formiq-documents

# ─── Optional ──────────────────────────────────────────────────────────────────

# Public URLs (update for production deployment)
# e.g., https://formiq.ke
FRONTEND_URL=http://localhost:3000
# e.g., https://formiq.ke/api
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ─── Paystack billing (optional) ───────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_WEBHOOK_SECRET=your-webhook-secret-hash

# Plan Codes
PAYSTACK_STARTER_PLAN_CODE=PLN_...
PAYSTACK_PROFESSIONAL_PLAN_CODE=PLN_...
